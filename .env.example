# The Brasilia Insider — ingestão
# Copie para .env e preencha. Sem essas vars, o scheduler roda fetch-only.

# Mesmo projeto Supabase do pipeline TS (dados-civicos).
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ── Data lake SIAFI (ingestao/lake/siafi/) ────────────────────────────────
# Cloudflare R2 (S3-compatible). Sem essas vars, grava em $LOCAL_LAKE_ROOT
# (default /tmp/brinsider-lake) para inspeção local via DuckDB.
R2_ACCOUNT_ID=
R2_BUCKET=brinsider-lake
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
LOCAL_LAKE_ROOT=/tmp/brinsider-lake
